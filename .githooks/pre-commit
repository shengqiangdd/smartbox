#!/bin/sh
# Git pre-commit hook for Wrench
#
# To install:
#   git config core.hooksPath .githooks
#
# Or symlink:
#   ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit

echo "🔍 Running pre-commit checks..."

# ── Frontend checks ──
cd frontend

echo "  → TypeScript..."
npx tsc --noEmit 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Aborting."
  exit 1
fi

echo "  → ESLint..."
npx eslint . --report-unused-disable-directives --max-warnings 0 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ ESLint errors found. Aborting."
  exit 1
fi

echo "  → Prettier..."
npx prettier --check "src/**/*.{ts,tsx,css,json}" 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ Prettier formatting issues found. Run: npm run format"
  exit 1
fi

echo "  → Unit tests..."
npx vitest run 2>/dev/null
if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed. Aborting."
  exit 1
fi

cd ..

# ── Backend checks (if cargo available) ──
if command -v cargo &> /dev/null; then
  cd backend
  echo "  → Rust check..."
  cargo check 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "❌ Rust compilation errors. Aborting."
    exit 1
  fi
  echo "  → Clippy..."
  cargo clippy -- -D warnings 2>/dev/null
  if [ $? -ne 0 ]; then
    echo "❌ Clippy warnings found. Aborting."
    exit 1
  fi
  cd ..
fi

echo "✅ All checks passed!"
