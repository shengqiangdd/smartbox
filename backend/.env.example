# Wrench Backend Configuration
# Copy this to .env and adjust values

# Server
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=3001
LOG_LEVEL=info

# CORS (comma-separated origins, empty = permissive)
CORS_ORIGINS=

# Frontend dist path (relative or absolute)
FRONTEND_DIST=./frontend/dist

# Plugins directory
PLUGINS_DIR=./plugins

# JWT Secret (REQUIRED for production — generates random key if empty, which resets on restart)
# Generate a secure key: openssl rand -hex 32
JWT_SECRET=

# OpenRouter API Key (for AI features)
OPENROUTER_API_KEY=

# Database path (optional, falls back to in-memory database)
# In Docker: defaults to /data/wrench.db
DATABASE_URL=
